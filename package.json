{
  "name": "mizu-ni-naru",
  "version": "0.1.0",
  "description": "mizu-ni-naru: floating bubbles where H and O drift, react, and everything eventually becomes water.",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build": "npm run typecheck && vite build",
    "preview": "vite preview",
    "test": "vitest run",
    "lint": "biome check",
    "lint:fix": "biome check --write",
    "typecheck": "tsc --noEmit -p tsconfig.json && tsc --noEmit -p tsconfig.sim.json",
    "depcruise": "depcruise src --config .dependency-cruiser.cjs",
    "dependency-graph": "depcruise src --config .dependency-cruiser.cjs --include-only \"^src\" --output-type dot | dot -T svg > dependency-graph.svg",
    "calibrate": "tsx scripts/calibrate.mts",
    "bench:sim": "tsx scripts/benchmark-sim.mts",
    "profile:sim": "tsx scripts/profile-sim.mts",
    "bench:detectors": "tsx scripts/benchmark-detectors.mts",
    "verify:detectors": "tsx scripts/verify-detector-compat.mts",
    "verify:splash-capacity": "tsx scripts/verify-inner-splash-capacity.mts",
    "bench:uploads": "tsx scripts/benchmark-attribute-uploads.mts",
    "bench:browser": "npm run build && tsx scripts/benchmark-browser.mts"
  },
  "keywords": [],
  "author": "",
  "license": "MIT",
  "dependencies": {
    "three": "^0.185.1"
  },
  "devDependencies": {
    "@biomejs/biome": "^1.9.4",
    "@types/three": "^0.185.0",
    "dependency-cruiser": "^18.0.0",
    "tsx": "^4.23.0",
    "typescript": "^6.0.3",
    "vite": "^8.1.3",
    "vitest": "^4.1.10"
  }
}
